# Example OIDC Configuration for LNbits

# This file shows example configurations for various OIDC providers.
# Copy the relevant section to your .env file and update with your values.

# The CUSTOM_ORG and CUSTOM_ICON settings allow you to customize the login button
# For example: "Login via Zitadel" with the Zitadel logo

# ============================================================================
# ZITADEL EXAMPLE
# ============================================================================
# LNBITS_AUTH_ALLOWED_METHODS=oidc-auth
# LNBITS_OIDC_DISCOVERY_URL=https://login.yourdomain.de/.well-known/openid-configuration
# LNBITS_OIDC_CLIENT_ID=your-zitadel-client-id@project-id
# LNBITS_OIDC_CLIENT_SECRET=your-zitadel-client-secret
# # Customize the login button to say "Login via Zitadel"
# LNBITS_OIDC_CLIENT_CUSTOM_ORG=Zitadel
# LNBITS_OIDC_CLIENT_CUSTOM_ICON=https://zitadel.com/favicon.svg

# ============================================================================
# AUTHENTIK EXAMPLE
# ============================================================================
# LNBITS_AUTH_ALLOWED_METHODS=oidc-auth
# LNBITS_OIDC_DISCOVERY_URL=https://authentik.yourdomain.com/application/o/lnbits/.well-known/openid-configuration
# LNBITS_OIDC_CLIENT_ID=your-authentik-client-id
# LNBITS_OIDC_CLIENT_SECRET=your-authentik-client-secret
# LNBITS_OIDC_CLIENT_CUSTOM_ORG=Authentik
# LNBITS_OIDC_CLIENT_CUSTOM_ICON=https://goauthentik.io/img/icon.png

# ============================================================================
# AUTH0 EXAMPLE
# ============================================================================
# LNBITS_AUTH_ALLOWED_METHODS=oidc-auth
# LNBITS_OIDC_DISCOVERY_URL=https://your-tenant.auth0.com/.well-known/openid-configuration
# LNBITS_OIDC_CLIENT_ID=your-auth0-client-id
# LNBITS_OIDC_CLIENT_SECRET=your-auth0-client-secret
# LNBITS_OIDC_CLIENT_CUSTOM_ORG=Auth0

# ============================================================================
# OKTA EXAMPLE
# ============================================================================
# LNBITS_AUTH_ALLOWED_METHODS=oidc-auth
# LNBITS_OIDC_DISCOVERY_URL=https://your-domain.okta.com/.well-known/openid-configuration
# LNBITS_OIDC_CLIENT_ID=your-okta-client-id
# LNBITS_OIDC_CLIENT_SECRET=your-okta-client-secret
# LNBITS_OIDC_CLIENT_CUSTOM_ORG=Okta

# ============================================================================
# GENERIC OIDC PROVIDER
# ============================================================================
# LNBITS_AUTH_ALLOWED_METHODS=oidc-auth
# LNBITS_OIDC_DISCOVERY_URL=https://your-provider.com/.well-known/openid-configuration
# LNBITS_OIDC_CLIENT_ID=your-client-id
# LNBITS_OIDC_CLIENT_SECRET=your-client-secret
# LNBITS_OIDC_CLIENT_CUSTOM_ORG=Your Provider Name
# LNBITS_OIDC_CLIENT_CUSTOM_ICON=https://your-provider.com/logo.png

# ============================================================================
# MULTIPLE AUTH METHODS
# ============================================================================
# You can enable multiple authentication methods at once:
# LNBITS_AUTH_ALLOWED_METHODS=username-password,oidc-auth,google-auth

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. The redirect URI in your OIDC provider must be set to:
#    https://your-lnbits-domain/api/v1/auth/oidc/token
#
# 2. Required scopes: openid, email, profile
#
# 3. The discovery URL must be accessible from your LNbits server
#
# 4. Always use HTTPS in production environments
